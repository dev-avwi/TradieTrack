{
  "expo": {
    "name": "JobRunner",
    "slug": "jobrunner",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "jobrunner",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/jobrunner-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafafa",
      "dark": {
        "backgroundColor": "#121417"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jobrunner.app",
      "buildNumber": "29",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "JobRunner needs camera access to take job photos",
        "NSPhotoLibraryUsageDescription": "JobRunner needs photo library access to upload job photos",
        "NSLocationWhenInUseUsageDescription": "JobRunner needs location access to track job sites",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "JobRunner needs location access for team tracking",
        "NSMicrophoneUsageDescription": "JobRunner needs microphone access to record voice notes for jobs",
        "NFCReaderUsageDescription": "JobRunner uses NFC for Tap to Pay contactless payments",
        "NSBluetoothAlwaysUsageDescription": "JobRunner uses Bluetooth to connect to card readers for payment processing",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "newArchEnabled": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jobrunner.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "NFC",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "@stripe/stripe-terminal-react-native",
        {
          "bluetoothBackgroundMode": false
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "JobRunner needs camera access to take job photos"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "JobRunner needs location access for team tracking"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8862E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "78e88ca7-014e-438b-8170-1ccae4cd9386"
      },
      "apiUrl": "https://jobrunner.com.au"
    },
    "updates": {
      "url": "https://u.expo.dev/78e88ca7-014e-438b-8170-1ccae4cd9386"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "avwi"
  }
}
